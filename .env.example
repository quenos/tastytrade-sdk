# These names match the existing Python call:
TT_API_CLIENT_SECRET=your-oauth-client-secret
TT_REFRESH_TOKEN=your-refresh-token

# These shorter aliases are also accepted.
TT_SECRET=your-oauth-client-secret
# TT_CLIENT_SECRET=your-oauth-client-secret
TT_REFRESH=your-refresh-token

# Optional values for your own scripts/apps. The SDK does not need TT_CLIENT_ID
# to refresh OAuth sessions, and Account.get(session) does not automatically use
# TT_ACCOUNT_ID because tastyware returns all accounts when no account is passed.
TT_CLIENT_ID=your-oauth-client-id
TT_ACCOUNT_ID=your-account-number

# Set true only when using sandbox/cert OAuth credentials and account numbers.
TT_IS_TEST=false
